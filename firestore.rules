rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles. CHANGED (S-1 fix): read is now owner-only. Reviews render
    // author name/avatar from denormalized fields on the review doc, and no
    // screen reads another user's doc, so public read is unnecessary and was
    // leaking email / pendingDeletionAt. Locking read closes that PII exposure.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /bookmarks/{bookmarkId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;

      // CHANGED (S-1 fix): create now verifies the author can't be forged and
      // that moderation fields start clean. userId must equal the caller;
      // reportCount/isHidden must start at 0/false; rating must be 1..5;
      // isAuthorDeleted (server-only, set by the deletion CF) cannot be planted.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.reportCount == 0
        && request.resource.data.isHidden == false
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
        && !('isAuthorDeleted' in request.resource.data);

      // CHANGED (S-1 fix): owner update is now restricted to the exact fields
      // updateReview writes, so an author can no longer flip isHidden/reportCount
      // to un-hide their own auto-hidden review or alter userId.
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating','comment','moodTags','priceTags','photoUrls','photoStoragePaths','updatedAt']);
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;

      // UNCHANGED: non-owner moderation +1 path (report flow transaction).
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['reportCount', 'isHidden'])
        && request.resource.data.reportCount == resource.data.get('reportCount', 0) + 1
        && (request.resource.data.isHidden == resource.data.get('isHidden', false)
             || request.resource.data.isHidden == true)
        && request.auth.uid != resource.data.userId;
    }

    // UNCHANGED from here down.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUserId == request.auth.uid;
      allow update, delete: if false;
      allow read: if request.auth != null
        && (resource == null || resource.data.reporterUserId == request.auth.uid);
    }

    match /appleAuth/{uid} {
      allow read, write: if false;
    }

    match /blocks/{blockId} {
      allow create: if request.auth != null
        && request.resource.data.blockerUserId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.blockerUserId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.blockerUserId == request.auth.uid;
      allow update: if false;
    }
  }
}
