rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /reviews/{uid}/{fileName} {
      allow read: if true;

      // CHANGED (S-1 fix): uploads capped at 10MB and restricted to images,
      // closing the cost-bomb / arbitrary-file-hosting hole.
      allow create: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // No in-place overwrites (review photo edits upload new filenames).
      allow update: if false;

      // CHANGED (S-1 fix): only the owner of the path may delete their photos.
      // Path-ownership (uid segment == caller) instead of a firestore.get on a
      // review doc: photos are uploaded BEFORE any review doc exists (pre-submit),
      // and the object path is keyed by uid, not reviewId, so a doc lookup would
      // target a nonexistent reviews/{uid} and wrongly deny every delete.
      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }
  }
}
