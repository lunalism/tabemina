rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Review photos are public reads (so the photo carousel works for
    // guests) and writable by any signed-in user. Per-author cleanup
    // happens client-side via FirebaseReviewRepository.deleteReview.
    match /reviews/{reviewId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
