rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /reviews/{reviewId}/{fileName} {
      allow read: if true;

      // CHANGED (S-1 fix): uploads capped at 10MB and restricted to images,
      // closing the cost-bomb / arbitrary-file-hosting hole.
      allow create: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // No in-place overwrites (review photo edits upload new filenames).
      allow update: if false;

      // CHANGED (S-1 fix): only the review's author may delete its photos.
      // deleteReview removes photos BEFORE the Firestore doc, so the doc is
      // still present here for the ownership lookup.
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/reviews/$(reviewId)).data.userId == request.auth.uid;
    }
  }
}
